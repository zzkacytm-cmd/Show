rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'zzkacytm@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidPortfolioItem(data) {
      return data.keys().hasAll(['title', 'description', 'imageUrls', 'order']) &&
             data.title is string && data.description is string &&
             data.imageUrls is list && data.order is number;
    }

    function isValidSkill(data) {
      return data.keys().hasAll(['name', 'level', 'order']) &&
             data.name is string && data.order is number;
    }

    function isValidCertificate(data) {
      return data.keys().hasAll(['name', 'issuer', 'order']) &&
             data.name is string && data.issuer is string && data.order is number;
    }

    function isValidExperience(data) {
      return data.keys().hasAll(['jobTitle', 'company', 'period', 'order']) &&
             data.jobTitle is string && data.company is string && data.order is number;
    }

    function isValidEducation(data) {
      return data.keys().hasAll(['school', 'degree', 'field', 'period', 'order']) &&
             data.school is string && data.degree is string && data.order is number;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['name']) && data.name is string;
    }

    // --- Collection Matches ---

    // 1. Profile Data - Fully Public for reading
    match /profile/{docId} {
      allow read: if true;
      allow write: if isAdmin() && (docId != 'config' || isValidProfile(incoming()));
    }

    // 2. Projects - Fully Public for reading
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin() && isValidPortfolioItem(incoming());
      allow delete: if isAdmin();
    }

    // 3. Skills - Fully Public for reading
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSkill(incoming());
      allow delete: if isAdmin();
    }

    // 4. Certificates - Fully Public for reading
    match /certificates/{certId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCertificate(incoming());
      allow delete: if isAdmin();
    }

    // 5. Experience - Fully Public for reading
    match /experience/{expId} {
      allow read: if true;
      allow write: if isAdmin() && isValidExperience(incoming());
      allow delete: if isAdmin();
    }

    // 6. Education - Fully Public for reading
    match /education/{eduId} {
      allow read: if true;
      allow write: if isAdmin() && isValidEducation(incoming());
      allow delete: if isAdmin();
    }

    // 7. Admins - Internal use
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Global Safety Net - MUST BE AT THE END
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
